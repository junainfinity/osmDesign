{
  "name": "osmdesign",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "description": "osmDesign desktop workbench for osmAPI and local OpenAI-compatible AI servers.",
  "license": "Apache-2.0",
  "bin": {
    "od": "./apps/daemon/dist/cli.js"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "tools-dev": "pnpm exec tools-dev",
    "tools-pack": "pnpm exec tools-pack",
    "build": "pnpm --filter @osmdesign/web build",
    "check:residual-js": "node --experimental-strip-types scripts/check-residual-js.ts",
    "test:e2e:live": "pnpm --filter @osmdesign/e2e test:e2e:live",
    "test": "pnpm -r --workspace-concurrency=1 --if-present run test",
    "test:ui:clean": "pnpm --filter @osmdesign/e2e test:ui:clean",
    "test:ui": "pnpm --filter @osmdesign/e2e test:ui",
    "test:ui:headed": "pnpm --filter @osmdesign/e2e test:ui:headed",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present run typecheck && pnpm --filter @osmdesign/daemon build && pnpm check:residual-js"
  },
  "devDependencies": {
    "@osmdesign/tools-dev": "workspace:0.1.0",
    "@osmdesign/tools-pack": "workspace:0.1.0"
  },
  "engines": {
    "node": "~24",
    "pnpm": ">=10.33.2 <11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
